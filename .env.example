# ----------------------------
# App runtime
# ----------------------------
APP_ENV=development
LOG_LEVEL=INFO
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8000
REQUEST_TIMEOUT_SECONDS=30

# ----------------------------
# Notion
# ----------------------------
NOTION_TOKEN=secret_xxx
NOTION_DATABASE_ID=your_newsroom_database_id
NOTION_DASHBOARD_PAGE_ID=your_dashboard_page_id
NOTION_BRAND_GUIDE_PAGE_ID=your_brand_guide_page_id

# Optional: DB IDs used by specific workflows
NOTION_PITCHES_DATABASE_ID=your_pitches_database_id
NOTION_ARTICLES_DATABASE_ID=your_articles_database_id

# ----------------------------
# Ollama
# ----------------------------
OLLAMA_HOST=http://localhost:11434
OLLAMA_GENERATION_MODEL=llama3.2:3b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text:v1.5


# ----------------------------
# Ollama
# ----------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# ----------------------------
# Chroma
# ----------------------------
CHROMA_PERSIST_DIRECTORY=./.chroma
CHROMA_COLLECTION_NAME=newsroom_archive
CHROMA_TOP_K=8

# ----------------------------
# Scheduler / polling
# ----------------------------
SCHEDULER_ENABLED=true
SCHEDULER_POLL_INTERVAL_SECONDS=120

# ----------------------------
# Traffic strategist (GA4 / Plausible)
# ----------------------------
ANALYTICS_PROVIDER=ga4
GA4_PROPERTY_ID=
GOOGLE_APPLICATION_CREDENTIALS=

PLAUSIBLE_BASE_URL=https://plausible.io/api/v1
PLAUSIBLE_API_KEY=
PLAUSIBLE_SITE_ID=

# ----------------------------
# Agency bridge
# ----------------------------
AGENCY_WEBHOOK_URL=
AGENCY_WEBHOOK_TOKEN=

# ----------------------------
# Workflow toggles (comma-separated)
# ----------------------------
ENABLED_WORKFLOWS=context_hunter,traffic_strategist,narrative_auditor,agency_bridge
